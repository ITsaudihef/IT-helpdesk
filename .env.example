# Database (PostgreSQL — Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/helpdesk"

# NextAuth — generate a real secret with: openssl rand -base64 32
# Never reuse the value committed here; it must be unique per environment.
NEXTAUTH_SECRET="replace-with-a-generated-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# SMTP (email notifications — optional, app runs without it but notifications won't send)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Local path for ticket attachment uploads.
# In production this MUST point at a persistent volume mount (e.g. Railway volume) —
# otherwise uploaded files are lost on every redeploy.
UPLOAD_DIR="./public/uploads"
